#!/usr/bin/env bash
# .agents/bin/agent-shell
# Launches a credential-shielded subshell for AI agents (Arc A BOOT-8).
#
# 1. Strips all ambient AWS credentials (SSO keys, session tokens, profiles)
# 2. Assumes the restricted itsjennyfiggy-agent-development role
#    (read-only terraform plan + explicit deny on destructive actions)
# 3. Exports ONLY the restricted temporary credentials into the subshell
# 4. Sets AGENT_SHELL=1 so the terraform wrapper can block direct applies
#
# Usage: .agents/bin/agent-shell [command...]
#   With no args: opens an interactive shielded shell.
#   With args:    runs the command inside the shielded environment.

set -euo pipefail

AGENT_ROLE_ARN="${AGENT_ROLE_ARN:-arn:aws:iam::940278682268:role/itsjennyfiggy-agent-development}"
SESSION_NAME="agent-shell-$(date +%s)"

# Assume the restricted role using the CURRENT (ambient) credentials,
# then discard those ambient credentials entirely.
CREDS_JSON=$(aws sts assume-role \
  --role-arn "$AGENT_ROLE_ARN" \
  --role-session-name "$SESSION_NAME" \
  --duration-seconds 14400 \
  --output json)

AWS_ACCESS_KEY_ID=$(echo "$CREDS_JSON" | jq -r '.Credentials.AccessKeyId')
AWS_SECRET_ACCESS_KEY=$(echo "$CREDS_JSON" | jq -r '.Credentials.SecretAccessKey')
AWS_SESSION_TOKEN=$(echo "$CREDS_JSON" | jq -r '.Credentials.SessionToken')

# Resolve the wrapper bin dir so the terraform intercept shadows the real binary.
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# env -i guarantees NO ambient variable (AWS_PROFILE, SSO cache hints, etc.) leaks through.
exec env -i \
  HOME="$HOME" \
  TERM="${TERM:-xterm-256color}" \
  LANG="${LANG:-en_US.UTF-8}" \
  PATH="$BIN_DIR:/usr/local/bin:/usr/bin:/bin" \
  AWS_ACCESS_KEY_ID="$AWS_ACCESS_KEY_ID" \
  AWS_SECRET_ACCESS_KEY="$AWS_SECRET_ACCESS_KEY" \
  AWS_SESSION_TOKEN="$AWS_SESSION_TOKEN" \
  AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-us-west-2}" \
  AGENT_SHELL=1 \
  bash "$@"
